# ──────────────────────────────────────────────────
# LendSignal 360 — Environment Variables
# Copy this to .env for local dev.
# Render uses render.yaml — no .env needed there.
# ──────────────────────────────────────────────────

# Global
APP_ENV=development
APP_NAME=LendSignal360

# Backend
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# Database — leave empty for in-memory SQLite (demo mode)
# For Render: omit or set to sqlite+pysqlite:///:memory:
DATABASE_URL=sqlite+pysqlite:///:memory:

# Redis — optional, skipped in demo mode
REDIS_URL=

# Auth mode
AUTH_MODE=demo
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI provider
# Set AI_PROVIDER=groq and GROQ_API_KEY to enable Live Credit Copilot.
# Leave empty to run in decision-support-only mode.
AI_PROVIDER=
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4.1-mini
GROQ_API_KEY=
GROQ_MODEL_STREAM=openai/gpt-oss-120b
GROQ_MODEL_STRUCTURED=openai/gpt-oss-120b
GROQ_TEMPERATURE=0.2
GROQ_MAX_TOKENS=1800
COPILOT_STREAMING_ENABLED=true
GROQ_RATE_LIMIT_ENABLED=true
GROQ_TPM_LIMIT=6000
GROQ_RPM_LIMIT=30

# Observability
SENTRY_DSN=
LOG_LEVEL=INFO

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=LendSignal 360
