# Global
APP_ENV=development
APP_NAME=LendSignal360

# Backend
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# Database
DATABASE_URL=postgresql+psycopg://lendsignal:lendsignal@localhost:5432/lendsignal

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth mode
AUTH_MODE=demo
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI provider
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4.1-mini
GROQ_API_KEY=
GROQ_MODEL_STREAM=llama-3.3-70b-versatile
GROQ_MODEL_STRUCTURED=openai/gpt-oss-20b
GROQ_TEMPERATURE=0.2
GROQ_MAX_TOKENS=1800
COPILOT_STREAMING_ENABLED=true

# Observability
SENTRY_DSN=
LOG_LEVEL=INFO

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=LendSignal 360
